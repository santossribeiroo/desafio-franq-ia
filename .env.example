# ── LLM Provider ──────────────────────────────────────────────────────────────
# "gemini" = Google Gemini API (recommended for evaluators — just needs GOOGLE_API_KEY)
# "ollama" = local model via Ollama (no API key, requires Ollama installed + model pulled)
LLM_PROVIDER=gemini

# ── Ollama (local) ─────────────────────────────────────────────────────────────
# Requires Ollama running: https://ollama.com
# Pull the model first: ollama pull qwen2.5:14b
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434

# ── Google Gemini (cloud) ──────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=gemini
# Get your key at: https://aistudio.google.com
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash
